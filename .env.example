# PIM dev environment template — copy to `.env` and override anything sensitive.
# `.env` and `.env.*.local` are gitignored.

APP_ENV=dev
APP_SECRET=ChangeMeBeforeDeploy

# Postgres — bootstrap superuser + table owner (runs initdb + migrations).
POSTGRES_DB=pim
POSTGRES_USER=pim
POSTGRES_PASSWORD=ChangeMeInDev

# AUD-002 (W1-1) — runtime application role (NOSUPERUSER, NOBYPASSRLS,
# non-owner) the api/worker connect as so FORCE ROW LEVEL SECURITY is enforced.
# Created + password-synced by docker/postgres/pim-init-app-role.sh.
APP_DB_USER=pim_app
APP_DB_PASSWORD=ChangeMeInDev

# Mercure (must match the JWT secret used by Symfony to publish events)
MERCURE_JWT_SECRET=ChangeMercureKey

# Meilisearch master key (read by Symfony + UI)
MEILI_MASTER_KEY=masterKeyPleaseChangeMe

# MinIO credentials (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Anthropic — set in .env (gitignored). Org-level cap $1000/month must also be set
# in the Anthropic Console as a defence-in-depth hardstop. See agent/lessons.md.
# ANTHROPIC_API_KEY=

# Shopify Partners development store credentials. See ticket 0.0.8 / Epic 0.9.
# SHOPIFY_ACCESS_TOKEN=
# SHOPIFY_STORE_DOMAIN=
