# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# UWAGA: nie ustawiamy tu `DATABASE_URL` — `config/packages/doctrine.yaml`
# w bloku `when@test:` ma `dbname_suffix: '_test%env(default::TEST_TOKEN)%'`,
# który automatycznie dorzuca `_test` do nazwy bazy z `.env`. Ustawienie
# pełnego DATABASE_URL tutaj zrobiłoby `pim_test_test` (suffix dwa razy).
# **Pułapka:** jeśli phpunit boot'uje kontener w env DEV (np. `cache:clear`
# nie odpalony, stary container compiled artifact), Foundry's
# `ResetDatabase` uderzy w *dev DB*, nie `pim_test`. Patrz memory
# `feedback_phpunit_dev_db_collision.md` (opis incydentu 2026-05-07).
# Zawsze odpalaj `php bin/console cache:clear --env=test` przed pierwszym
# runem PHPUnit po przerwie / zmianach w `config/packages/`.

# Force in-band handling of every Messenger envelope inside the test
# kernel — async-routed messages must execute under the same transaction
# the test asserts on. CI overrides this via a real env var to
# `in-memory://` when individual tests need to introspect the queue.
MESSENGER_TRANSPORT_DSN=sync://
MESSENGER_IMPORT_TRANSPORT_DSN=sync://
