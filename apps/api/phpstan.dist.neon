# PIM API — PHPStan configuration.
#
# Level: max (= 10) per CLAUDE.md "Definicja Done" — automation-first quality gate.
# Extensions auto-loaded via phpstan/extension-installer:
#   - phpstan-symfony  (container, console, validators)
#   - phpstan-doctrine (entity manager, query builder typing)
#   - phpstan-strict-rules (boolean coercion, defensive comparisons)
#
# Custom rules (custom PHPStan rule blokująca flush() w pętli bez clear()) dochodzą
# w momencie pierwszego batch handler'a — sekcja 3.10 architektury, Sprint 0 ticket 0.0.13.

parameters:
    level: max

    paths:
        - bin
        - public
        - src
        - tests

    excludePaths:
        - var/*
        - vendor/*
        # Skeleton bootstrap shipped by symfony/test-pack — touching it forces
        # us to fight Symfony's own conventions. Re-included once we extend it.
        - tests/bootstrap.php

    # Symfony container introspection — needs the dev cache built before PHPStan runs.
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
        consoleApplicationLoader: tests/console-application.php

    # Doctrine integration — ObjectManager loader for query builder return types.
    doctrine:
        objectManagerLoader: tests/object-manager.php

    # Modern strict-typed codebase — every function and method should declare types.
    checkMissingCallableSignature: true
    checkUninitializedProperties: true
    treatPhpDocTypesAsCertain: true

    # Allow ignored-error patterns to be unmatched as the codebase grows from skeleton.
    reportUnmatchedIgnoredErrors: false

    # Skip noisy errors that are not actionable in early-stage skeleton.
    ignoreErrors:
        # API Platform 4 attributes use generic `array` typing extensively.
        - identifier: missingType.iterableValue
          paths:
              - src/ApiResource/*
              - src/Entity/*
        # Test setUp() initialises properties that PHPStan cannot follow.
        - identifier: property.uninitialized
          paths:
              - tests/*
        # PHPUnit's $this->createStub() / $this->createMock() trigger
        # strict-rules dynamic-static-call warnings; the framework itself
        # designs them as instance methods on TestCase.
        - identifier: staticMethod.dynamicCall
          paths:
              - tests/*
        # `assertTrue(true)` is the documented PHPUnit pattern for "no
        # exception thrown" tests where there is nothing else to assert on.
        - identifier: staticMethod.alreadyNarrowedType
          paths:
              - tests/*
        # Tenant-scoped entities declare `?Tenant` in PHP for the brief
        # window between `new` and TenantAssignmentListener::prePersist;
        # the schema column itself is NOT NULL. The invariant is verified
        # by the listener tests and at INSERT time by the database. New
        # TenantScoped entities should be added here as they land.
        - identifier: doctrine.associationType
          paths:
              - src/Catalog/Domain/Entity/Attribute.php
              - src/Catalog/Domain/Entity/AttributeGroup.php
              - src/Catalog/Domain/Entity/AttributeOption.php
              - src/Catalog/Domain/Entity/ObjectType.php
              - src/Catalog/Domain/Entity/CatalogObject.php
              - src/Catalog/Domain/Entity/ObjectValue.php
              - src/Catalog/Domain/Entity/AssociationType.php
              - src/Catalog/Domain/Entity/Association.php
              - src/Channel/Domain/Entity/Channel.php
