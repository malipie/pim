# PIM API — PHPStan configuration.
#
# Level: max (= 10) per CLAUDE.md "Definicja Done" — automation-first quality gate.
# Extensions auto-loaded via phpstan/extension-installer:
#   - phpstan-symfony  (container, console, validators)
#   - phpstan-doctrine (entity manager, query builder typing)
#   - phpstan-strict-rules (boolean coercion, defensive comparisons)
#
# Custom rules — three ship today:
#   - RequiresPermissionAnnotationRule (RBAC-P1-010 #649) — every #[Route]
#     method must declare #[RequiresPermission] or #[NoPermissionRequired].
#   - HardcodedRoleCheckRule (RBAC-P1-010 #649) — forbids $user->hasRole(),
#     isAdmin(), in_array(..., getRoles()) outside Identity/Infrastructure/Security/.
#   - FlushWithoutClearInLoopRule (AUD-011, W1-8) — a Messenger handler that
#     flush()es inside a batch loop without clear() OOMs the FrankenPHP worker
#     (architektura §3.10); exempts AbstractBatchHandler subclasses.
# See docs/static-analysis/custom-rules.md for the full inventory.

includes:
    - phpstan/services.neon
    - phpstan-baseline.neon

parameters:
    level: max

    paths:
        - bin
        - public
        - src
        - tests

    excludePaths:
        - var/*
        - vendor/*
        # Skeleton bootstrap shipped by symfony/test-pack — touching it forces
        # us to fight Symfony's own conventions. Re-included once we extend it.
        - tests/bootstrap.php
        # AUD-011 (W1-8) — deliberately-malformed fixtures for
        # FlushWithoutClearInLoopRuleTest (flush-in-loop-without-clear handlers).
        # RuleTestCase analyses them explicitly with the rule in isolation; the
        # main analysis must NOT flag them as production findings.
        - tests/Architecture/PHPStan/Fixtures/*

    # Symfony container introspection — needs the dev cache built before PHPStan runs.
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
        consoleApplicationLoader: tests/console-application.php

    # Doctrine integration — ObjectManager loader for query builder return types.
    doctrine:
        objectManagerLoader: tests/object-manager.php

    # Modern strict-typed codebase — every function and method should declare types.
    checkMissingCallableSignature: true
    checkUninitializedProperties: true
    treatPhpDocTypesAsCertain: true

    # Fail when an `ignoreErrors` entry no longer matches anything — keeps
    # the ignore list honest as the codebase evolves (audit MEDIUM-001).
    # Each ignore stays only as long as the underlying error is still
    # being thrown; otherwise CI surfaces the dead entry on the next run.
    reportUnmatchedIgnoredErrors: true

    # Tightly-scoped ignores for noise that is structural rather than a
    # real bug. Every entry below is explicitly justified — when an
    # ignore stops matching, `reportUnmatchedIgnoredErrors` flips CI red
    # and the entry must be removed or moved.
    ignoreErrors:
        # Test setUp() initialises properties that PHPStan cannot follow.
        - identifier: property.uninitialized
          paths:
              - tests/*
        # PHPUnit's $this->createStub() / $this->createMock() trigger
        # strict-rules dynamic-static-call warnings; the framework itself
        # designs them as instance methods on TestCase.
        - identifier: staticMethod.dynamicCall
          paths:
              - tests/*
        # `assertTrue(true)` is the documented PHPUnit pattern for "no
        # exception thrown" tests where there is nothing else to assert on.
        - identifier: staticMethod.alreadyNarrowedType
          paths:
              - tests/*
        # Test-only services live in `tests/Support/` and are registered
        # under `when@test:`. PHPStan introspects the dev container so it
        # cannot see them, but they exist at PHPUnit runtime.
        - identifier: symfonyContainer.serviceNotFound
          paths:
              - tests/*
        # Tenant-scoped entities declare `?Tenant` in PHP for the brief
        # window between `new` and TenantAssignmentListener::prePersist;
        # the schema column itself is NOT NULL. The invariant is verified
        # by the listener tests and at INSERT time by the database. New
        # TenantScoped entities should be added here as they land.
        - identifier: doctrine.associationType
          # The ignore covers the union write window (new entity →
          # TenantAssignmentListener::prePersist sets the NOT NULL `tenant`
          # association) on every entity below: the PHP property is
          # `?Tenant` for the brief gap between `new` and prePersist, while
          # the join-column is `nullable=false`.
          #
          # AUD-080: `reportUnmatched: false` is RETAINED here — deliberately,
          # not "just in case". Whether phpstan-doctrine emits this error for
          # the `src/Import/Domain/*` entities (which extend AggregateRoot)
          # is non-deterministic across run modes: a single-threaded
          # `--debug` run reports all 9, but a parallel run (CI default)
          # intermittently resolves their metadata before the @var doc-block
          # and emits nothing for them, leaving the ignore unmatched. With
          # the global `reportUnmatchedIgnoredErrors: true`, an unmatched
          # entry would flip CI red on those flaky runs. Tolerating the
          # unmatched ignore for this one group is the lesser evil; the
          # non-AggregateRoot entities below always match.
          reportUnmatched: false
          paths:
              - src/Catalog/Domain/Entity/Attribute.php
              - src/Catalog/Domain/Entity/AttributeGroup.php
              - src/Catalog/Domain/Entity/AttributeOption.php
              - src/Catalog/Domain/Entity/ObjectType.php
              - src/Catalog/Domain/Entity/CatalogObject.php
              - src/Catalog/Domain/Entity/ObjectValue.php
              - src/Catalog/Domain/Entity/ObjectRelation.php
              - src/Catalog/Domain/Entity/BulkEditJob.php
              - src/Catalog/Domain/Entity/SavedView.php
              - src/Catalog/Domain/Entity/BulkSession.php
              - src/Channel/Domain/Entity/Channel.php
              - src/Channel/Domain/Entity/ChannelCategoryNode.php
              - src/Channel/Domain/Entity/ObjectChannelPlacement.php
              - src/Channel/Domain/Entity/ChannelCategoryNodeMapping.php
              - src/Asset/Domain/Entity/Asset.php
              - src/ApiConfigurator/Domain/Entity/ApiProfile.php
              - src/ApiConfigurator/Domain/Entity/ApiKey.php
              - src/Identity/Domain/Entity/TenantAgentConfig.php
              - src/Catalog/Domain/Entity/MenuConfiguration.php
              # Import/Domain entities extend AggregateRoot — their
              # doctrine.associationType emission is the flaky one the
              # `reportUnmatched: false` above guards against (see comment).
              - src/Import/Domain/Entity/ImportSession.php
              - src/Import/Domain/Entity/StagedFile.php
              - src/Import/Domain/Entity/ImportUndoLog.php
              - src/Import/Domain/Entity/ImportLog.php
              - src/Import/Domain/Entity/ImportProfile.php
              - src/Import/Domain/Entity/ImportSource.php
              - src/Import/Domain/Entity/ImportSourceLog.php
              - src/Import/Domain/Entity/ImportSchedule.php
              # Integration/Generic (ADR-0022, epic APIC) — also extends
              # AggregateRoot, same `?Tenant` write-window as the Import group.
              - src/Integration/Generic/Domain/Entity/Connection.php
              - src/Integration/Generic/Domain/Entity/RemoteEndpoint.php
              - src/Integration/Generic/Domain/Entity/RemoteField.php
              - src/Integration/Generic/Domain/Entity/FieldMapping.php
              - src/Integration/Generic/Domain/Entity/SyncBinding.php
              - src/Import/Domain/Entity/ImportScheduleRun.php
              - src/Export/Domain/Entity/ExportSession.php
              - src/Export/Domain/Entity/ExportProfile.php
              - src/Backup/Domain/Entity/Backup.php
              - src/Channel/Domain/Entity/TenantLocale.php
              - src/Channel/Domain/Entity/ChannelPublicationProfile.php
        # Tenant aggregate exposes legacy `$enabledLocales` + `$primaryLocale`
        # marked `@deprecated` by #870 (LOC-02) until LOC-07 (#875) migrates
        # `/settings/tenant` to consume `tenant_locales`. The Tenant class
        # itself still mutates them through `enableLocale()` /
        # `disableLocale()` / `changePrimaryLocale()` to keep
        # `WorkspaceController` and `TenantConfigController` functional —
        # treat in-class access as the supported migration path. With the
        # warmed dev container in place before analysis, PHPStan
        # consistently sees the @deprecated annotation and emits the
        # errors, so the pattern always matches — no `reportUnmatched: false`
        # suppression needed (AUD-080).
        - identifier: property.deprecated
          paths:
              - src/Shared/Domain/Tenant.php
