<?xml version="1.0" encoding="UTF-8"?>
<resources xmlns="https://api-platform.com/schema/metadata/resources-3.0"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="https://api-platform.com/schema/metadata/resources-3.0
                               https://api-platform.com/schema/metadata/resources-3.0.xsd">

    <resource class="App\Channel\Domain\Entity\ChannelObjectTypeMapping"
              shortName="ChannelObjectTypeMapping">

        <normalizationContext>
            <values>
                <value name="groups">
                    <values>
                        <value>channel_mapping:read</value>
                    </values>
                </value>
            </values>
        </normalizationContext>

        <operations>
            <operation class="ApiPlatform\Metadata\GetCollection"
                       uriTemplate="/channel_object_type_mappings{._format}"
                       security="is_granted('READ', 'App\\Channel\\Domain\\Entity\\Channel')"/>

            <operation class="ApiPlatform\Metadata\Get"
                       uriTemplate="/channel_object_type_mappings/{id}{._format}"
                       security="is_granted('READ', 'App\\Channel\\Domain\\Entity\\Channel')"/>

            <operation class="ApiPlatform\Metadata\Patch"
                       uriTemplate="/channel_object_type_mappings/{id}{._format}"
                       input="App\Channel\Infrastructure\ApiPlatform\Resource\ChannelObjectTypeMappingPatchInput"
                       processor="App\Channel\Infrastructure\ApiPlatform\State\ChannelObjectTypeMappingProcessor"
                       security="is_granted('UPDATE', 'App\\Channel\\Domain\\Entity\\Channel')">
                <denormalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>channel_mapping:patch</value>
                            </values>
                        </value>
                    </values>
                </denormalizationContext>
            </operation>
        </operations>
    </resource>
</resources>
