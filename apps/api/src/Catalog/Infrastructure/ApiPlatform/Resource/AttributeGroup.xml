<?xml version="1.0" encoding="UTF-8"?>
<resources xmlns="https://api-platform.com/schema/metadata/resources-3.0"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="https://api-platform.com/schema/metadata/resources-3.0
                               https://api-platform.com/schema/metadata/resources-3.0.xsd">

    <resource class="App\Catalog\Domain\Entity\AttributeGroup"
              shortName="AttributeGroup">

        <normalizationContext>
            <values>
                <value name="groups">
                    <values>
                        <value>admin:read</value>
                    </values>
                </value>
            </values>
        </normalizationContext>

        <operations>
            <operation class="ApiPlatform\Metadata\GetCollection"
                       uriTemplate="/attribute_groups{._format}"
                       security="is_granted('READ', 'App\\Catalog\\Domain\\Entity\\AttributeGroup')"/>

            <operation class="ApiPlatform\Metadata\Get"
                       uriTemplate="/attribute_groups/{id}{._format}"
                       security="is_granted('READ', object)"/>

            <operation class="ApiPlatform\Metadata\Post"
                       uriTemplate="/attribute_groups{._format}"
                       input="App\Catalog\Infrastructure\ApiPlatform\Resource\AttributeGroupInput"
                       processor="App\Catalog\Infrastructure\ApiPlatform\State\AttributeGroupProcessor"
                       security="is_granted('CREATE', 'App\\Catalog\\Domain\\Entity\\AttributeGroup')">
                <denormalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>attribute_group:create</value>
                            </values>
                        </value>
                    </values>
                </denormalizationContext>
            </operation>

            <operation class="ApiPlatform\Metadata\Patch"
                       uriTemplate="/attribute_groups/{id}{._format}"
                       input="App\Catalog\Infrastructure\ApiPlatform\Resource\AttributeGroupPatchInput"
                       processor="App\Catalog\Infrastructure\ApiPlatform\State\AttributeGroupProcessor"
                       security="is_granted('UPDATE', object)">
                <denormalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>attribute_group:patch</value>
                            </values>
                        </value>
                    </values>
                </denormalizationContext>
            </operation>

            <operation class="ApiPlatform\Metadata\Delete"
                       uriTemplate="/attribute_groups/{id}{._format}"
                       processor="App\Catalog\Infrastructure\ApiPlatform\State\AttributeGroupProcessor"
                       security="is_granted('DELETE', object)"/>
        </operations>
    </resource>
</resources>
