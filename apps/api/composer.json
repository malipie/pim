{
    "name": "pim/api",
    "description": "PIM API (Symfony 7.4 LTS + API Platform 4 + FrankenPHP 2.x worker mode)",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "api-platform/doctrine-orm": "^4.3.3",
        "api-platform/symfony": "^4.3.3",
        "damienharper/auditor-bundle": "^6.3",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^2.18.2",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^3.6.3",
        "league/csv": "^9.28",
        "league/flysystem-aws-s3-v3": "^3.32",
        "league/flysystem-bundle": "^3.7",
        "lexik/jwt-authentication-bundle": "^3",
        "meilisearch/meilisearch-php": "^1.16",
        "phpdocumentor/reflection-docblock": "^5.6.7",
        "phpoffice/phpspreadsheet": "^5.7",
        "phpstan/phpdoc-parser": "^2.3.2",
        "runtime/frankenphp-symfony": "^0.2",
        "spomky-labs/otphp": "^11.4",
        "symfony/asset": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/expression-language": "7.4.*",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "7.4.*",
        "symfony/mercure-bundle": "^0.4.2",
        "symfony/messenger": "7.4.*",
        "symfony/mime": "7.4.*",
        "symfony/property-access": "7.4.*",
        "symfony/property-info": "7.4.*",
        "symfony/rate-limiter": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/uid": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/yaml": "7.4.*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "lint": [
            "@phpstan",
            "@cs-check"
        ],
        "phpstan": "phpstan analyse --memory-limit=512M --no-progress",
        "deptrac": "deptrac analyse --no-progress --no-cache",
        "cs-check": "php-cs-fixer fix --dry-run --diff --using-cache=no",
        "cs-fix": "php-cs-fixer fix --using-cache=no",
        "test": [
            "Composer\\Config::disableProcessTimeout",
            "@php bin/console cache:clear --env=test --quiet",
            "@php vendor/bin/phpunit"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "deptrac/deptrac": "^4.6",
        "doctrine/doctrine-fixtures-bundle": "^4",
        "friendsofphp/php-cs-fixer": "^3.65",
        "phpstan/extension-installer": "^1",
        "phpstan/phpstan": "^2",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-doctrine": "^2",
        "phpstan/phpstan-strict-rules": "^2",
        "phpstan/phpstan-symfony": "^2",
        "phpunit/phpunit": "^12",
        "rector/rector": "^2.4",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/http-client": "7.4.*",
        "zenstruck/foundry": "^2"
    }
}
