# PIM — PRODUCTION environment template (AUD-009 / AUD-046 / AUD-047, W1-4).
#
# Copy to an UNTRACKED `.env.prod` (gitignored by `.env.*`) on the deploy host
# and replace EVERY `__CHANGE_ME...__` placeholder with a real, freshly
# generated secret. Every key below is consumed by docker-compose.prod.yml.
#
#   cp .env.prod.example .env.prod
#   $EDITOR .env.prod                      # fill in real secrets
#   docker compose --env-file .env.prod \
#       -f docker-compose.yml -f docker-compose.prod.yml config -q   # validate
#   docker compose --env-file .env.prod \
#       -f docker-compose.yml -f docker-compose.prod.yml up -d        # launch
#
# IMPORTANT — the production overlay is FAIL-LOUD: every secret below is wired
# as `${VAR:?error}` in docker-compose.prod.yml, so a missing/empty value makes
# `docker compose config|up` abort non-zero instead of silently booting on a
# well-known default. Do NOT add defaults here; that would defeat the guard.
#
# Secrets MAY instead live in the Symfony Secrets Vault (config/secrets/prod/)
# for application-level secrets — see docs/operations/secrets-runbook.md. The
# infrastructure secrets below (Postgres / MinIO / Meili / Mercure credentials)
# are read by docker-compose at container-launch time and therefore must be
# provided as env (vault values are only available *inside* a booted Symfony
# process, not to compose interpolation).
#
# ── Deploy runbook (order matters) ────────────────────────────────────────
#   1. Generate every secret (commands noted per key below) and write .env.prod.
#   2. Inject the Symfony vault decryption key out-of-band:
#        export SYMFONY_DECRYPTION_SECRET="$(cat prod.decrypt.private.key)"
#      (or mount config/secrets/prod/prod.decrypt.private.php) — see runbook.
#   3. Validate:  docker compose --env-file .env.prod -f docker-compose.yml \
#                   -f docker-compose.prod.yml config -q   → must exit 0.
#   4. Launch:    ... up -d   (Mailpit is excluded from prod automatically.)
# ───────────────────────────────────────────────────────────────────────────

# Run the API container in production mode.
APP_ENV=prod
APP_DEBUG=0

# ── Symfony application secret — MUST set, NO default ──────────────────────
# Signs CSRF tokens, UriSigner URLs, session/remember-me cookies.
# Generate: php -r 'echo bin2hex(random_bytes(16));'
APP_SECRET=__CHANGE_ME_app_secret_32_hex__

# ── PostgreSQL — MUST set, NO default ──────────────────────────────────────
# POSTGRES_USER/POSTGRES_PASSWORD = bootstrap superuser + table owner (`pim`),
# used by doctrine_migrations for DDL. APP_DB_USER/APP_DB_PASSWORD = runtime
# role (`pim_app`, NOSUPERUSER + NOBYPASSRLS) the api/worker connect as so
# FORCE ROW LEVEL SECURITY is enforced. Generate each: openssl rand -base64 24
POSTGRES_DB=pim
POSTGRES_USER=pim
POSTGRES_PASSWORD=__CHANGE_ME_postgres_owner_password__
APP_DB_USER=pim_app
APP_DB_PASSWORD=__CHANGE_ME_postgres_runtime_password__

# ── Mercure (SSE hub) JWT secret — MUST set, NO default ────────────────────
# Signs the publisher + subscriber JWTs. Minimum 256 bits.
# Generate: openssl rand -hex 32
MERCURE_JWT_SECRET=__CHANGE_ME_mercure_jwt_min_256_bits__
# Public origin the SPA connects to / topics are built from. Match the real host.
MERCURE_PUBLIC_URL=https://pim.example.com/.well-known/mercure
MERCURE_TOPIC_BASE=https://pim.example.com

# ── Meilisearch master key — MUST set, NO default ──────────────────────────
# Required because the prod overlay forces MEILI_ENV=production (AUD-046), which
# makes the master key mandatory. Generate: openssl rand -base64 32
MEILI_MASTER_KEY=__CHANGE_ME_meili_master_key__

# ── MinIO / S3 object storage — MUST set, NO default ───────────────────────
# Root credentials for the asset/backup/import/export buckets; also used by
# pgBackRest to push WAL. Generate each: openssl rand -base64 24
MINIO_ROOT_USER=__CHANGE_ME_minio_access_key__
MINIO_ROOT_PASSWORD=__CHANGE_ME_minio_secret_key__

# ── Alertmanager receiver — MUST set (no real default) ─────────────────────
# PagerDuty / Slack / Opsgenie / generic webhook the Prometheus alerts route to.
# The overlay defaults this to http://example.invalid/ so an unconfigured deploy
# fails loudly during smoke instead of silently dropping alerts — set it for real.
ALERTMANAGER_WEBHOOK_URL=__CHANGE_ME_alertmanager_webhook_url__
