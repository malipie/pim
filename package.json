{
  "name": "pim",
  "version": "0.0.1",
  "private": true,
  "description": "PIM — Product Information Management (single-tenant deployed, multi-tenant ready)",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "docker compose up",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f",
    "stack:reset": "docker compose down -v && docker compose up -d",
    "stack:rebuild": "docker compose build --no-cache",
    "perf:list": "./scripts/perf-list-products.sh",
    "backup:run": "docker compose exec -T database su -s /bin/sh postgres -c 'pgbackrest --stanza=pim backup'",
    "backup:info": "docker compose exec -T database pgbackrest --stanza=pim info",
    "backup:restore": "./scripts/pim-backup-restore.sh",
    "backup:test": "./scripts/test-pgbackrest-restore.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:php": "docker compose exec -T api composer lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "{apps/admin,packages,scripts,.husky,.github}/**/*.{ts,tsx,js,jsx,json,jsonc}": [
      "pnpm exec biome check --no-errors-on-unmatched"
    ],
    "/*.{json,jsonc,js,cjs,mjs}": [
      "pnpm exec biome check --no-errors-on-unmatched"
    ],
    "apps/api/**/*.php": [
      "./scripts/lint-staged-php.sh"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^21.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.16"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2",
      "qs": ">=6.15.2",
      "dompurify": ">=3.4.9"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-vmh5-mc38-953g",
        "GHSA-vxpw-j846-p89q",
        "GHSA-hm92-r4w5-c3mj"
      ]
    }
  },
  "dependencies": {
    "react-hook-form": "7.77.0"
  }
}
